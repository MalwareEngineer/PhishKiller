# Darla Configuration
PK_DEBUG=true
PK_LOG_LEVEL=DEBUG

# ─── Auth & Identity (RFC 0001) ──────────────────────────────────────
# Community / local-evaluation defaults.  See docs/auth/no-auth.md
# (Phase 8) and the deployment-repo RFC for production setup.
#
# To enable OIDC: set PK_AUTH_ENABLED=true and provide PK_OIDC_ISSUER
# + PK_OIDC_AUDIENCE (and PK_OIDC_SUBJECT_CLAIM=oid for Entra).
PK_AUTH_ENABLED=false
# Required acknowledgement when auth is disabled — this exact string,
# nothing else.  Verbose by design (RFC §16 guardrail #3).
PK_I_UNDERSTAND_AUTH_IS_OFF=yes-only-for-local-eval
# Disabled-mode requires localhost-only bind (RFC §16 guardrail #4).
PK_BIND_ADDRESS=127.0.0.1

# Infrastructure credentials — used by docker-compose.yml
POSTGRES_USER=darla
POSTGRES_PASSWORD=changeme
RABBITMQ_USER=darla
RABBITMQ_PASS=changeme

# Database (localhost URLs used by API server and local dev worker)
# The Docker worker overrides these to use container hostnames automatically.
PK_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/darla
PK_SYNC_DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/darla

# Redis
PK_REDIS_URL=redis://localhost:6379/0

# Celery
PK_CELERY_BROKER_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@localhost:5672//
PK_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Feed API Keys (optional for community feeds)
PK_PHISHTANK_API_KEY=

# Analysis
PK_KIT_DOWNLOAD_DIR=./downloads
PK_KIT_EXTRACT_DIR=./extracted
PK_MAX_KIT_SIZE_MB=50
PK_DOWNLOAD_TIMEOUT=30
