# PhishKiller Configuration
PK_DEBUG=true
PK_LOG_LEVEL=DEBUG

# Database (localhost URLs used by API server and local dev worker)
# The Docker worker overrides these to use container hostnames automatically.
PK_DATABASE_URL=postgresql+asyncpg://phishkiller:phishkiller@localhost:5432/phishkiller
PK_SYNC_DATABASE_URL=postgresql+psycopg2://phishkiller:phishkiller@localhost:5432/phishkiller

# Redis
PK_REDIS_URL=redis://localhost:6379/0

# Celery
PK_CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
PK_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Feed API Keys (optional for community feeds)
PK_PHISHTANK_API_KEY=
PK_URLHAUS_AUTH_KEY=

# Analysis
PK_KIT_DOWNLOAD_DIR=./downloads
PK_KIT_EXTRACT_DIR=./extracted
PK_MAX_KIT_SIZE_MB=50
PK_DOWNLOAD_TIMEOUT=30
