# Frontend (Vite) environment template — copy to `.env.local` (gitignored).
#
# All `VITE_*` vars are baked into the bundle at build time, so changes
# require a rebuild (`npm run build` or restart `npm run dev`).

# ─── Auth & Identity (RFC 0001) ──────────────────────────────────────
# Default is community / local-evaluation mode — no login flow, no
# tokens, all API calls go out anonymously.  The backend's disabled
# mode (RFC §16) accepts them as long as the guardrails pass.
VITE_AUTH_ENABLED=false

# When VITE_AUTH_ENABLED=true, all four of the below must be set.
# A half-configured build (one missing) falls back to disabled mode
# with a console warning — see frontend/src/auth/oidcConfig.ts.
#
# Examples:
#   Entra:    https://login.microsoftonline.com/<tenant-id>/v2.0
#   Okta:     https://<your-org>.okta.com/oauth2/default
#   Keycloak: https://<host>/realms/<realm>
VITE_OIDC_AUTHORITY=
# Application (client) ID of your "Darla SPA" app registration.
VITE_OIDC_CLIENT_ID=
# Scope for the Darla API (resource server).
#   Entra:    api://<api-client-id>/access_as_user
#   Okta:     darla.access (or whatever you named the scope)
#   Keycloak: darla
VITE_OIDC_API_SCOPE=
